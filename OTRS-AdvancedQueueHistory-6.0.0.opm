<?xml version="1.0" encoding="utf-8" ?>
<otrs_package version="1.0">
    <Name>OTRS-AdvancedQueueHistory</Name>
    <Version>6.0.0</Version>
    <Framework Minimum="6.0.0">6.0.x</Framework>
    <Vendor>K1tba</Vendor>
    <URL>https://otrs.com/</URL>
    <License>GNU GENERAL PUBLIC LICENSE Version 3, 29 June 2007</License>
    <Description Lang="en">Advanced queue history</Description>
    <Description Lang="ru">Расширенная история очередей</Description>
    <Filelist>
        <File Location="Custom/Kernel/System/Queue.pm" Permission="660" Encode="Base64"></File>
    </Filelist>
    <DatabaseInstall Type="post">
        <Table Name="queue_history_type">
            <Column Name="id" Required="true" PrimaryKey="true" AutoIncrement="true" Type="SMALLINT"/>
            <Column Name="name" Required="true" Size="200" Type="VARCHAR"/>
            <Column Name="comments" Required="false" Size="250" Type="VARCHAR"/>
            <Column Name="valid_id" Required="true" Type="SMALLINT"/>
            <Column Name="create_time" Required="true" Type="DATE"/>
            <Column Name="create_by" Required="true" Type="INTEGER"/>
            <Column Name="change_time" Required="true" Type="DATE"/>
            <Column Name="change_by" Required="true" Type="INTEGER"/>
            <Unique Name="queue_history_type_name">
                <UniqueColumn Name="name"/>
            </Unique>
            <ForeignKey ForeignTable="valid">
                <Reference Local="valid_id" Foreign="id"/>
            </ForeignKey>
            <ForeignKey ForeignTable="users">
                <Reference Local="create_by" Foreign="id"/>
                <Reference Local="change_by" Foreign="id"/>
            </ForeignKey>
        </Table>
        <Insert Table="queue_history_type">
            <Data Key="id" Type="AutoIncrement">1</Data>
            <Data Key="name" Type="Quote">FirstResponseTimeUpdate</Data>
            <Data Key="valid_id">1</Data>
            <Data Key="create_by">1</Data>
            <Data Key="create_time">current_timestamp</Data>
            <Data Key="change_by">1</Data>
            <Data Key="change_time">current_timestamp</Data>
        </Insert>
        <Insert Table="queue_history_type">
            <Data Key="id" Type="AutoIncrement">2</Data>
            <Data Key="name" Type="Quote">UpdateTimeUpdate</Data>
            <Data Key="valid_id">1</Data>
            <Data Key="create_by">1</Data>
            <Data Key="create_time">current_timestamp</Data>
            <Data Key="change_by">1</Data>
            <Data Key="change_time">current_timestamp</Data>
        </Insert>
        <Insert Table="queue_history_type">
            <Data Key="id" Type="AutoIncrement">3</Data>
            <Data Key="name" Type="Quote">SolutionTimeUpdate</Data>
            <Data Key="valid_id">1</Data>
            <Data Key="create_by">1</Data>
            <Data Key="create_time">current_timestamp</Data>
            <Data Key="change_by">1</Data>
            <Data Key="change_time">current_timestamp</Data>
        </Insert>
        <Table Name="queue_history">
            <Column Name="id" Required="true" PrimaryKey="true" AutoIncrement="true" Type="BIGINT"/>
            <Column Name="name" Required="true" Size="200" Type="VARCHAR"/>
            <Column Name="history_type_id" Required="true" Type="SMALLINT"/>
            <Column Name="queue_id" Required="true" Type="INTEGER"/>
            <Column Name="create_time" Required="true" Type="DATE"/>
            <Column Name="create_by" Required="true" Type="INTEGER"/>
            <Column Name="change_time" Required="true" Type="DATE"/>
            <Column Name="change_by" Required="true" Type="INTEGER"/>
            <Index Name="queue_history_ticket_id">
                <IndexColumn Name="ticket_id"/>
            </Index>
            <Index Name="queue_history_article_id">
                <IndexColumn Name="article_id"/>
            </Index>
            <Index Name="queue_history_history_type_id">
                <IndexColumn Name="history_type_id"/>
            </Index>
            <Index Name="queue_history_queue_id">
                <IndexColumn Name="queue_id"/>
            </Index>
            <Index Name="queue_history_create_time">
                <IndexColumn Name="create_time"/>
            </Index>
            <ForeignKey ForeignTable="queue">
                <Reference Local="queue_id" Foreign="id"/>
            </ForeignKey>
            <ForeignKey ForeignTable="queue_history_type">
                <Reference Local="history_type_id" Foreign="id"/>
            </ForeignKey>
            <ForeignKey ForeignTable="users">
                <Reference Local="create_by" Foreign="id"/>
                <Reference Local="change_by" Foreign="id"/>
            </ForeignKey>
        </Table>
    </DatabaseInstall>
    <DatabaseUninstall Type="pre">
        <TableDrop Name="queue_history"/>
        <TableDrop Name="queue_history_type"/>
    </DatabaseUninstall>
</otrs_package>